<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Status UI: visible when idle -->
    <LinearLayout
        android:id="@+id/status_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FireLinkTab"
            android:textColor="#FF6B6B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/status_mdns"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● mDNS: iniciando..."
            android:textColor="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/status_dial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● DIAL: iniciando..."
            android:textColor="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/status_cast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Cast v2: iniciando..."
            android:textColor="#888888"
            android:textSize="16sp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Busca este dispositivo en el menú Cast de Chrome/Brave"
            android:textColor="#555555"
            android:textSize="13sp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- WebView: shown when an app is launched via DIAL -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

</FrameLayout>
