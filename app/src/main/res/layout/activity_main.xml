<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- ── Idle screen ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/status_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="80dp"
        android:paddingEnd="80dp"
        android:paddingTop="40dp"
        android:paddingBottom="40dp">

        <!-- Title with gradient applied in code -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FireLink"
            android:textSize="58sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            android:textColor="#FF4500"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transmite cualquier app al Fire TV"
            android:textColor="#555555"
            android:textSize="15sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.08"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="48dp"/>

        <!-- URL card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/url_card_bg"
            android:paddingStart="36dp"
            android:paddingEnd="36dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abre en cualquier navegador de escritorio"
                android:textColor="#555555"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/url_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="https://—.—.—.—:8443"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="#FF8C00"/>

        </LinearLayout>

        <!-- Cert hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑  Primera vez: instala el certificado CA desde la sección de ajuste en la página"
            android:textColor="#7A5500"
            android:textSize="13sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="28dp"/>

        <!-- Mobile note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💻  Solo funciona desde navegadores de escritorio (Windows · macOS · Linux)"
            android:textColor="#3A3A3A"
            android:textSize="13sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="8dp"/>

        <!-- CA cert download hint -->
        <TextView
            android:id="@+id/ca_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑  Primera vez: instala el certificado CA desde http://—:8080/ca.crt"
            android:textColor="#2A2A2A"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="6dp"/>

        <!-- Receiver status dot -->
        <TextView
            android:id="@+id/status_receiver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● preparando…"
            android:textColor="#333333"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="36dp"/>

    </LinearLayout>

    <!-- ── WebRTC receiver (fullscreen when casting) ────────────── -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

</FrameLayout>
